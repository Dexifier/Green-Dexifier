# ---- Server-only secrets (never exposed to the browser) ----
EXOLIX_API_KEY=
EXOLIX_API_URL=https://exolix.com/api/v2
CHAINFLIP_API_KEY=
CHAINFLIP_BROKER_URL=https://chainflip-broker.io

# Database (Postgres)
DATABASE_URL=
# Direct (non-pooled) connection used by prisma migrate. Optional.
DIRECT_URL=

# ---- Public values (shipped to the browser — safe by design) ----
# Rango API keys are public per-dApp identifiers; the widget requires them
# client-side. Rate-limit by domain in your Rango dashboard.
NEXT_PUBLIC_RANGO_API_KEY_BASIC=
NEXT_PUBLIC_RANGO_API_KEY=
NEXT_PUBLIC_RANGO_API_URL=https://api.rango.exchange
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
NEXT_PUBLIC_DEXIFIER_EXPLORER=

# Cookieless analytics (Plausible). Leave empty to disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
